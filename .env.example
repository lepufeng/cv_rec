# ========== Application ==========
APP_ENV=dev
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-please

# ========== Logging ==========
# 自动记录结构化日志到本地文件（JSON Lines），同时保留控制台输出
LOG_TO_FILE=true
LOG_FILE_PATH=./data/logs/app.log
LOG_FILE_MAX_MB=10
LOG_FILE_BACKUP_COUNT=5
LOG_REQUEST_ENABLED=true

# ========== Database ==========
# 本地默认 SQLite, 生产可换 postgresql+asyncpg://user:pass@host/db
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# ========== Storage ==========
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/uploads

# ========== Model Provider ==========
# 选择主力模型 provider: glm | qwen
MODEL_PROVIDER=glm
# 默认是否开启 Thinking: enabled | disabled。用户上传/插件请求可单次覆盖
MODEL_THINKING_MODE=disabled

# 智谱 GLM (推荐 MVP 期使用 GLM-4.6V-Flash 限免)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_OCR_MODEL=glm-ocr
GLM_VISION_MODEL=glm-4.6v-flash
GLM_CHAT_MODEL=glm-4.6v-flash
# 可选：用于 facts 审阅、schema 判断等更重语义任务；为空则回退到 GLM_CHAT_MODEL
GLM_REASONING_MODEL=

# 通义千问 (备选)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_OCR_MODEL=
QWEN_VISION_MODEL=qwen-vl-plus
QWEN_CHAT_MODEL=qwen-vl-plus
# 可选：用于 facts 审阅、schema 判断等更重语义任务；为空则回退到 QWEN_CHAT_MODEL
QWEN_REASONING_MODEL=

# ========== File Limits ==========
MAX_FILE_SIZE_MB=10

# ========== Cache TTL ==========
FILL_PLAN_CACHE_TTL_DAYS=7
